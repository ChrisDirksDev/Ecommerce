{
  "name": "ecommerce-monorepo",
  "private": true,
  "scripts": {
    "client": "cd frontend && npm run dev",
    "server": "cd backend && npm run dev",
    "fulldev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "npm --prefix backend run build && npm --prefix frontend run build",
    "seed": "npm --prefix backend run seed",
    "test": "npm --prefix backend test -- --runInBand && npm --prefix frontend test",
    "lint": "npm --prefix frontend run lint"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "uuid": "^11.1.0"
  }
}
